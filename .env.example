# ==============================================================================
# SM Data Pipeline - Airflow Environment Configuration
# ==============================================================================
# 루트 .env 파일의 공통 설정을 사용하며, Airflow 특화 설정만 포함
# ==============================================================================

# ------------------------------------------------------------------------------
# 데이터베이스 설정 (루트 .env 우선 사용)
# ------------------------------------------------------------------------------
DB_HOST=${DB_HOST:-127.0.0.1}
DB_PORT=${DB_PORT:-3306}
DB_USER=${DB_USERNAME:-root}
DB_PASSWORD=${DB_PASSWORD:-password}
DB_NAME=${DB_DATABASE:-sm_artist_insights}

# ------------------------------------------------------------------------------
# Airflow 메타데이터 DB 설정
# ------------------------------------------------------------------------------
# Airflow와 애플리케이션이 동일한 MySQL 사용
AIRFLOW_DB_HOST=${DB_HOST:-127.0.0.1}
AIRFLOW_DB_PORT=${DB_PORT:-3306}
AIRFLOW_DB_USER=${DB_USERNAME:-root}
AIRFLOW_DB_PASSWORD=${DB_PASSWORD:-password}
AIRFLOW_DB_NAME=airflow_metadata

# ------------------------------------------------------------------------------
# Airflow 웹 UI 설정
# ------------------------------------------------------------------------------
AIRFLOW_WEBSERVER_PORT=8081
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@sm-artist-insights.com

# ------------------------------------------------------------------------------
# Discord 웹훅 (루트 .env 우선 사용)
# ------------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=${DISCORD_WEBHOOK_URL:-https://discord.com/api/webhooks/your_webhook_url}

# ------------------------------------------------------------------------------
# 크롤링 설정
# ------------------------------------------------------------------------------
# YouTube Data API v3 (선택 사항)
YOUTUBE_API_KEY=

# X (Twitter) API (선택 사항)
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# Reddit API (선택 사항)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SM-Artist-Insights-Crawler/1.0

# ------------------------------------------------------------------------------
# 크롤러 스케줄 설정
# ------------------------------------------------------------------------------
# Cron 표현식 (기본: 매일 오전 9시)
YOUTUBE_CRAWLER_SCHEDULE=0 9 * * *
X_CRAWLER_SCHEDULE=0 10 * * *
COMMUNITY_CRAWLER_SCHEDULE=0 11 * * *

# ------------------------------------------------------------------------------
# 로깅
# ------------------------------------------------------------------------------
LOG_LEVEL=${LOG_LEVEL:-INFO}
AIRFLOW_LOG_LEVEL=${LOG_LEVEL:-INFO}

# ------------------------------------------------------------------------------
# Python 환경
# ------------------------------------------------------------------------------
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
