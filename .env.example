# ==============================================================================
# SM Data Pipeline - Airflow Environment Configuration
# ==============================================================================
# Airflow 크롤러용 환경변수 설정
# PostgreSQL에 크롤링 원본 데이터 저장
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL 설정 (크롤링 데이터 저장)
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=sm_crawled_data

# ------------------------------------------------------------------------------
# Airflow 메타데이터 DB 설정 (PostgreSQL 사용)
# ------------------------------------------------------------------------------
# Airflow 내부 메타데이터는 airflow_metadata 데이터베이스 사용
# docker-compose.yml에서 자동 설정됨
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:your_postgres_password_here@postgres:5432/airflow_metadata

# ------------------------------------------------------------------------------
# Airflow 웹 UI 설정
# ------------------------------------------------------------------------------
AIRFLOW_WEBSERVER_PORT=8081
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@sm-artist-insights.com

# ------------------------------------------------------------------------------
# Discord 웹훅 알림
# ------------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# ------------------------------------------------------------------------------
# API 키 설정 (크롤링용)
# ------------------------------------------------------------------------------
# YouTube Data API v3
# https://console.cloud.google.com/ 에서 발급
YOUTUBE_API_KEY=

# X (Twitter) API
# https://developer.twitter.com/ 에서 발급
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# Reddit API (선택 사항)
# https://www.reddit.com/prefs/apps 에서 발급
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SM-Artist-Insights-Crawler/1.0

# ------------------------------------------------------------------------------
# 크롤러 스케줄 설정 (Cron 표현식)
# ------------------------------------------------------------------------------
# YouTube: 매일 오전 12시 (자정)
YOUTUBE_CRAWLER_SCHEDULE=0 0 * * *

# X(Twitter): 6시간마다 (00, 06, 12, 18시)
X_CRAWLER_SCHEDULE=0 */6 * * *

# Community: 매일 오전 8시, 오후 8시
COMMUNITY_CRAWLER_SCHEDULE=0 8,20 * * *

# ------------------------------------------------------------------------------
# 로깅 설정
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
AIRFLOW_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Python 환경
# ------------------------------------------------------------------------------
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ------------------------------------------------------------------------------
# 참고: 데이터 플로우
# ------------------------------------------------------------------------------
# 1. Airflow 크롤러 → PostgreSQL (sm_crawled_data) ← 원본 데이터
# 2. AI Backend 분석 → MySQL (sm_artist_insights) ← 분석 결과
# 3. Laravel Admin Panel → MySQL 읽기 ← 시각화
